---
import { Clock, Unplug, TrendingDown, AlertTriangle, ChevronDown } from '@lucide/astro';
import type { Lang } from '../../i18n/ui';
import { t } from '../../i18n/ui';

interface Props {
  lang?: Lang;
}

const { lang = 'es' } = Astro.props;

const icons = [Clock, Unplug, TrendingDown, AlertTriangle];
const painPoints = t(lang, 'problem.painPoints') as { title: string; desc: string }[];
---

<section class="section w-screen h-full shrink-0 snap-start flex flex-col justify-center px-5 sm:px-10 pt-16 pb-20 md:px-20 lg:px-24 md:pt-0 md:pb-0 overflow-y-auto no-scrollbar" data-index="1">
  <div class="max-w-5xl mx-auto w-full my-auto md:my-0 section-content">
    <div class="mb-6 md:mb-12">
      <p class="text-slate-600 text-xs md:text-sm tracking-[0.2em] mb-3 md:mb-4">{t(lang, 'problem.label')}</p>
      <h2 class="text-3xl sm:text-4xl md:text-6xl lg:text-7xl font-bold tracking-tighter">
        {t(lang, 'problem.heading.line1')}<br />
        <span class="text-blue-600">{t(lang, 'problem.heading.line2')}</span>
      </h2>
    </div>

    <div class="grid grid-cols-2 gap-3 sm:gap-4 md:gap-6 max-w-4xl">
      {painPoints.map(({ title, desc }, i) => {
        const Icon = icons[i];
        return (
          <div class="problem-card group flex flex-col md:flex-row gap-2 md:gap-3 p-3 md:p-6 bg-white/[0.02] border border-white/5 rounded-xl md:rounded-2xl hover:border-red-900/40 transition-all duration-300">
            <div class="w-8 h-8 md:w-12 md:h-12 shrink-0 bg-red-500/10 text-red-400 rounded-lg md:rounded-xl flex items-center justify-center">
              <Icon class="w-4 h-4 md:w-6 md:h-6" />
            </div>
            <div class="flex-1 min-w-0">
              <button class="problem-card-toggle w-full flex items-center gap-1 text-left" type="button" aria-expanded="false">
                <h3 class="font-bold text-sm md:text-lg flex-1">{title}</h3>
                <ChevronDown class="problem-card-chevron md:hidden w-4 h-4 shrink-0 text-slate-500 transition-transform duration-300" />
              </button>
              <div class="problem-card-body">
                <div class="overflow-hidden min-h-0">
                  <p class="text-slate-500 text-xs md:text-base leading-relaxed pt-0.5 md:pt-1">{desc}</p>
                </div>
              </div>
            </div>
          </div>
        );
      })}
    </div>

    <p class="mt-6 md:mt-10 text-slate-500 text-sm md:text-base max-w-md">
      {t(lang, 'problem.footer')}
    </p>
  </div>
</section>

<style>
  .problem-card-body {
    display: grid;
    grid-template-rows: 0fr;
    transition: grid-template-rows 300ms ease;
  }
  .problem-card-body.is-open {
    grid-template-rows: 1fr;
  }
  @media (min-width: 768px) {
    .problem-card-body {
      grid-template-rows: 1fr;
    }
    .problem-card-toggle {
      pointer-events: none;
      cursor: default;
    }
  }
</style>

<script>
  function initProblemAccordion() {
    document.querySelectorAll('.problem-card:not([data-acc-init])').forEach(card => {
      card.setAttribute('data-acc-init', 'true');
      const toggle = card.querySelector('.problem-card-toggle');
      const body = card.querySelector('.problem-card-body');
      const chevron = card.querySelector('.problem-card-chevron');
      toggle?.addEventListener('click', () => {
        if (window.innerWidth >= 768) return;
        const isOpen = body?.classList.toggle('is-open');
        chevron?.classList.toggle('rotate-180', isOpen);
        toggle.setAttribute('aria-expanded', String(isOpen ?? false));
      });
    });
  }
  initProblemAccordion();
  document.addEventListener('astro:page-load', initProblemAccordion);
</script>

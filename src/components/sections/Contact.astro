---
import { Mail, MessageCircle, Calendar, Send as SendIcon } from '@lucide/astro';
import type { Lang } from '../../i18n/ui';
import { t } from '../../i18n/ui';

interface Props {
  lang?: Lang;
}

const { lang = 'es' } = Astro.props;

const icons = [MessageCircle, Calendar, SendIcon, Mail];
const colorClasses = ['text-green-500', 'text-blue-500', 'text-blue-500', 'text-purple-400'];
const borderClasses = ['hover:border-green-600/30', 'hover:border-blue-600/30', 'hover:border-blue-600/30', 'hover:border-purple-600/30'];

const whatsappText = lang === 'es'
  ? 'Hola%20Rubén%2C%20me%20gustaría%20consultarte%20acerca%20de%20...'
  : 'Hi%20Rubén%2C%20I%20would%20like%20to%20ask%20you%20about%20...';

const urls = [
  `https://wa.me/34614830864?text=${whatsappText}`,
  'https://cal.com/ruben-perez-yumwg8/30min',
  'https://t.me/rpidev',
  'mailto:ruben@rpidev.com',
];

const channelTexts = t(lang, 'contact.channels') as { label: string; desc: string }[];
---

<section class="section w-screen h-full shrink-0 snap-start flex flex-col justify-center px-5 sm:px-10 pt-16 pb-20 md:px-8 lg:px-12 md:pt-0 md:pb-0 overflow-y-auto no-scrollbar" data-index="5">
  <div class="max-w-4xl w-full text-center section-content mx-auto my-auto md:my-0">
    <h2 class="text-4xl sm:text-5xl md:text-6xl lg:text-7xl xl:text-8xl font-bold tracking-tighter mb-3 md:mb-4 outline-text">{t(lang, 'contact.heading')}</h2>
    <p class="text-base md:text-xl text-slate-400 mb-2 md:mb-4">
      {t(lang, 'contact.line1')}
    </p>
    <p class="text-sm md:text-base text-slate-600 mb-6 md:mb-10">
      {t(lang, 'contact.line2')}
    </p>

    <div class="grid grid-cols-2 sm:grid-cols-4 gap-3 sm:gap-4 mb-6 md:mb-10">
      {channelTexts.map(({ label, desc }, i) => {
        const Icon = icons[i];
        return (
          <a
            href={urls[i]}
            target="_blank"
            rel="noopener noreferrer"
            class={`group p-4 md:p-5 bg-white/[0.02] border border-white/5 rounded-xl md:rounded-2xl ${borderClasses[i]} transition-all duration-300 text-left`}
          >
            <Icon class={`w-5 h-5 md:w-6 md:h-6 mb-2 md:mb-3 ${colorClasses[i]}`} />
            <p class="text-sm md:text-base font-bold">{label}</p>
            <p class="text-[10px] md:text-xs text-slate-500 mt-0.5">{desc}</p>
          </a>
        );
      })}
    </div>

    <p class="text-xs md:text-sm text-slate-500 mb-4 md:mb-6 max-w-md mx-auto">
      {t(lang, 'contact.note')}
    </p>

    <div class="flex justify-center gap-4 md:gap-6">
      <a href="https://www.linkedin.com/in/rubén-pérez-izuel-a02607189" target="_blank" rel="noopener noreferrer" class="text-slate-600 hover:text-blue-500 transition-colors text-xs md:text-sm font-bold tracking-widest">
        LINKEDIN
      </a>
      <a href="https://github.com/rperezpin" target="_blank" rel="noopener noreferrer" class="text-slate-600 hover:text-blue-500 transition-colors text-xs md:text-sm font-bold tracking-widest">
        GITHUB
      </a>
      <a href="https://www.instagram.com/rpi.dev/" target="_blank" rel="noopener noreferrer" class="text-slate-600 hover:text-blue-500 transition-colors text-xs md:text-sm font-bold tracking-widest">
        INSTAGRAM
      </a>
    </div>
  </div>
</section>

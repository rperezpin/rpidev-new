---
import { Globe, Zap, Link2, MessageCircle, ChevronDown } from '@lucide/astro';
import type { Lang } from '../../i18n/ui';
import { t } from '../../i18n/ui';

interface Props {
  lang?: Lang;
}

const { lang = 'es' } = Astro.props;

const icons = [Globe, Zap, Link2, MessageCircle];
const services = t(lang, 'services.items') as { title: string; desc: string }[];
---

<section class="section w-screen h-full shrink-0 snap-start flex flex-col justify-center px-5 sm:px-10 pt-16 pb-20 md:px-20 lg:px-24 md:pt-0 md:pb-0 overflow-y-auto no-scrollbar" data-index="2" data-scrollable>
  <div class="max-w-6xl mx-auto w-full my-auto md:my-0 section-content">
    <div class="mb-6 md:mb-12 short:mb-3">
      <p class="text-slate-600 text-xs md:text-sm tracking-[0.2em] mb-3 md:mb-4 short:mb-1">{t(lang, 'services.label')}</p>
      <h2 class="text-3xl sm:text-4xl md:text-6xl lg:text-7xl short:text-[clamp(1.5rem,6.5vh,2.25rem)] font-bold tracking-tighter short:mb-1">
        {t(lang, 'services.heading.line1')}<br />
        <span class="text-blue-600">{t(lang, 'services.heading.line2')}</span>
      </h2>
    </div>

    <div class="grid grid-cols-2 gap-3 sm:gap-4 md:gap-6">
      {services.map(({ title, desc }, i) => {
        const Icon = icons[i];
        return (
          <div class="service-card group p-4 md:p-8 short:p-3 bg-white/[0.02] border border-white/5 rounded-xl md:rounded-3xl hover:border-blue-600/30 transition-all duration-500">
            <div class="w-10 h-10 md:w-14 md:h-14 short:w-8 short:h-8 bg-blue-600/10 text-blue-500 rounded-lg md:rounded-2xl flex items-center justify-center mb-3 md:mb-6 short:mb-2 group-hover:scale-110 transition-transform">
              <Icon class="w-5 h-5 md:w-6 md:h-6" />
            </div>
            <button class="service-card-toggle w-full flex items-center gap-1 text-left" type="button" aria-expanded="false">
              <h3 class="text-sm md:text-xl font-bold uppercase tracking-tight flex-1">{title}</h3>
              <ChevronDown class="service-card-chevron md:hidden w-4 h-4 shrink-0 text-slate-500 transition-transform duration-300" />
            </button>
            <div class="service-card-body">
              <div class="overflow-hidden min-h-0">
                <p class="text-slate-400 text-xs md:text-base leading-relaxed pt-1 md:pt-3">{desc}</p>
              </div>
            </div>
          </div>
        );
      })}
    </div>
  </div>
</section>

<style>
  .service-card-body {
    display: grid;
    grid-template-rows: 0fr;
    transition: grid-template-rows 300ms ease;
  }
  .service-card-body.is-open {
    grid-template-rows: 1fr;
  }
  @media (min-width: 768px) {
    .service-card-body {
      grid-template-rows: 1fr;
    }
    .service-card-toggle {
      pointer-events: none;
      cursor: default;
    }
  }
</style>

<script>
  function initServiceAccordion() {
    document.querySelectorAll('.service-card:not([data-acc-init])').forEach(card => {
      card.setAttribute('data-acc-init', 'true');
      const toggle = card.querySelector('.service-card-toggle');
      const body = card.querySelector('.service-card-body');
      const chevron = card.querySelector('.service-card-chevron');
      toggle?.addEventListener('click', () => {
        if (window.innerWidth >= 768) return;
        const isOpen = body?.classList.toggle('is-open');
        chevron?.classList.toggle('rotate-180', isOpen);
        toggle.setAttribute('aria-expanded', String(isOpen ?? false));
      });
    });
  }
  initServiceAccordion();
  document.addEventListener('astro:page-load', initServiceAccordion);
</script>

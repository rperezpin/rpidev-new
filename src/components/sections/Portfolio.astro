---
import { ExternalLink } from '@lucide/astro';
import type { Lang } from '../../i18n/ui';
import { t } from '../../i18n/ui';

interface Props {
  lang?: Lang;
}

const { lang = 'es' } = Astro.props;

const projectData = [
  { tech: ['Astro', 'Tailwind'], url: 'https://desguacesvaldeferrin.es', status: 'production' },
  { tech: ['Astro', 'Tailwind'], url: 'https://casvisol.com', status: 'production' },
  { tech: ['Astro', 'Tailwind'], url: 'https://www.hebepsicologa.com', status: 'production' },
  { tech: ['Python', 'React', 'FastAPI'], url: 'https://www.seopilot.es', status: 'production' },
  { tech: ['Astro'], url: 'https://choose.com', status: 'dev' },
  { tech: ['Astro', 'React'], url: 'https://www.rpidev.com', status: 'production' },
  { tech: ['Next.js', 'PostgreSQL'], url: 'https://crm-rpidev.vercel.app/', status: 'production' },
  { tech: ['React', 'Firebase'], url: 'https://landing-basic-planner.vercel.app/', status: 'dev' },
  { tech: ['Next.js', 'MUI'], url: 'https://landing-verifax.vercel.app/', status: 'dev' },
];

const projectTexts = t(lang, 'portfolio.projects') as { name: string; type: string; desc: string }[];
const viewProject = t(lang, 'portfolio.viewProject') as string;
const statusProd = t(lang, 'portfolio.statusProduction') as string;
const statusDev = t(lang, 'portfolio.statusDev') as string;

const projects = projectData.map((data, i) => ({
  ...data,
  ...projectTexts[i],
  statusLabel: data.status === 'production' ? statusProd : statusDev,
}));
---

<section class="section w-screen h-full shrink-0 snap-start flex flex-col justify-center px-5 pb-20 md:px-24 md:pb-16 overflow-y-auto no-scrollbar" style="padding-top: max(4rem, calc(var(--nav-h, 4rem) + 1.5rem))" data-index="4">
  <div class="max-w-7xl mx-auto w-full section-content flex flex-col flex-1 min-h-0">
    <div class="flex justify-between items-end mb-5 md:mb-10 flex-shrink-0">
      <div>
        <p class="text-slate-600 text-xs md:text-sm tracking-[0.2em] mb-2 md:mb-4">{t(lang, 'portfolio.label')}</p>
        <h2 class="text-3xl sm:text-5xl md:text-7xl font-bold tracking-tighter">{t(lang, 'portfolio.heading')}</h2>
      </div>
      <span class="hidden sm:block text-slate-600 text-sm tracking-[0.15em]">{t(lang, 'portfolio.badge')}</span>
    </div>

    <!-- Mobile: lista vertical compacta con scroll -->
    <div class="flex md:hidden flex-col gap-2 flex-1 min-h-0 overflow-y-auto no-scrollbar w-full overscroll-contain" data-scrollable>
      {projects.map(({ name, type, desc, url, status, statusLabel }) => (
        <a href={url} target="_blank" rel="noopener noreferrer" class="flex items-center gap-3 p-3 bg-white/[0.02] border border-white/5 rounded-xl active:border-blue-600/30 transition-all w-full min-w-0">
          <div class="shrink-0">
            <span class="text-blue-500 text-[9px] font-bold tracking-[0.15em]">{type}</span>
            <h3 class="text-sm font-bold">{name}</h3>
            <p class="text-slate-500 text-[11px] leading-snug">{desc}</p>
          </div>
          <div class="ml-auto shrink-0 flex flex-col items-end gap-1">
            <span class={`text-[8px] font-bold tracking-wider px-1.5 py-0.5 rounded-full ${
              status === 'production'
                ? 'bg-emerald-500/10 text-emerald-400'
                : 'bg-amber-500/10 text-amber-400'
            }`}>
              {statusLabel}
            </span>
            <ExternalLink class="w-3 h-3 text-slate-600" />
          </div>
        </a>
      ))}
    </div>

    <!-- Desktop: grid -->
    <div class="hidden md:flex flex-col flex-1 min-h-0 overflow-y-auto no-scrollbar" data-scrollable>
    <div class="grid grid-cols-2 lg:grid-cols-3 gap-5 pb-4">
      {projects.map(({ name, type, desc, tech, url, status, statusLabel }) => (
        <article class="group relative p-6 bg-white/[0.02] border border-white/5 rounded-2xl hover:border-blue-600/30 transition-all duration-300">
          <div class="flex justify-between items-start mb-4">
            <span class="text-blue-500 text-xs font-bold tracking-[0.2em]">{type}</span>
            <span class={`text-[10px] font-bold tracking-wider px-2 py-0.5 rounded-full ${
              status === 'production'
                ? 'bg-emerald-500/10 text-emerald-400'
                : 'bg-amber-500/10 text-amber-400'
            }`}>
              {statusLabel}
            </span>
          </div>
          <h3 class="text-xl font-bold mb-2">{name}</h3>
          <p class="text-slate-500 text-sm leading-relaxed mb-4">{desc}</p>
          <div class="flex flex-wrap gap-1.5 mb-4">
            {tech.map((techName) => (
              <span class="text-xs text-slate-500 bg-white/5 px-2 py-0.5 rounded-md">{techName}</span>
            ))}
          </div>
          <a
            href={url}
            target="_blank"
            rel="noopener noreferrer"
            class="inline-flex items-center gap-1.5 text-xs text-blue-500 hover:text-white font-bold tracking-widest transition-colors"
          >
            {viewProject} <ExternalLink class="w-3.5 h-3.5" />
          </a>
        </article>
      ))}
    </div>
    </div>
  </div>
</section>

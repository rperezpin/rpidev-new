---
import '../styles/global.css';
import type { Lang } from '../i18n/ui';
import { getLocalizedPath, t } from '../i18n/ui';

interface Props {
  title: string;
  description: string;
  canonical?: string;
  noIndex?: boolean;
  lang?: Lang;
}

const {
  title,
  description,
  canonical = Astro.url.href,
  noIndex = false,
  lang = 'es',
} = Astro.props;

const GTM_ID = 'GTM-W65MZL7G';

const cookieText      = t(lang, 'cookie.text') as string;
const cookieAccept    = t(lang, 'cookie.accept') as string;
const cookieDecline   = t(lang, 'cookie.decline') as string;
const cookieLearnMore = t(lang, 'cookie.learnMore') as string;
const cookiesHref     = lang === 'es' ? '/cookies' : '/en/cookies';

const siteUrl = 'https://www.rpidev.com';
const ogImage = `${siteUrl}/images/og-default.jpg`;
const currentPath = lang === 'es' ? Astro.url.pathname : Astro.url.pathname.replace(/^\/en/, '') || '/';
---

<!doctype html>
<html lang={lang}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="theme-color" content="#1a1a2e" />
    <meta name="author" content="Rubén Pérez Izuel" />
    <meta name="referrer" content="strict-origin-when-cross-origin" />
    <meta http-equiv="X-Content-Type-Options" content="nosniff" />
    <meta http-equiv="X-Frame-Options" content="SAMEORIGIN" />
    <meta http-equiv="Permissions-Policy" content="accelerometer=(), autoplay=(), camera=(), geolocation=(), gyroscope=(), magnetometer=(), microphone=(), payment=(), usb=()" />
    <meta
      http-equiv="Content-Security-Policy"
      content="default-src 'self'; base-uri 'self'; form-action 'self'; frame-ancestors 'self'; object-src 'none'; img-src 'self' data: https:; font-src 'self' https://fonts.gstatic.com; style-src 'self' 'unsafe-inline' https://fonts.googleapis.com; script-src 'self' 'unsafe-inline' https://www.googletagmanager.com; connect-src 'self' https://www.google-analytics.com https://analytics.google.com https://www.googletagmanager.com; upgrade-insecure-requests"
    />
    <!-- Ocultar banner hasta que JS decida mostrarlo -->
    <style is:inline>#cookie-banner { display: none; }</style>

    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonical} />

    {noIndex
      ? <meta name="robots" content="noindex, nofollow" />
      : <meta name="robots" content="index, follow, max-snippet:-1, max-image-preview:large, max-video-preview:-1" />
    }

    <!-- Hreflang: alternate language versions -->
    <link rel="alternate" hreflang="es" href={`${siteUrl}${getLocalizedPath('es', currentPath)}`} />
    <link rel="alternate" hreflang="en" href={`${siteUrl}${getLocalizedPath('en', currentPath)}`} />
    <link rel="alternate" hreflang="x-default" href={`${siteUrl}${getLocalizedPath('es', currentPath)}`} />

    <!-- Open Graph -->
    <meta property="og:type" content="website" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonical} />
    <meta property="og:image" content={ogImage} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:image:alt" content={title} />
    <meta property="og:image:type" content="image/jpeg" />
    <meta property="og:locale" content={lang === 'es' ? 'es_ES' : 'en_US'} />
    <meta property="og:locale:alternate" content={lang === 'es' ? 'en_US' : 'es_ES'} />
    <meta property="og:site_name" content="RPI Dev" />

    <!-- Twitter Card -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImage} />

    <!-- Geo targeting -->
    <meta name="geo.region" content="ES-GR" />
    <meta name="geo.placename" content="Granada" />

    <!-- Favicon -->
    <link rel="icon" href="/favicon.ico" sizes="48x48" />
    <link rel="icon" type="image/png" href="/favicon.png" />
    <link rel="apple-touch-icon" href="/favicon.png" />

    <!-- Preconnect -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link rel="preconnect" href="https://www.googletagmanager.com" />

    <!-- Google Tag Manager: consent mode + init (debe ir antes que cualquier otro script) -->
    {import.meta.env.PROD && (
      <Fragment set:html={`<script>(function(w,d,s,l,i){
  w[l]=w[l]||[];
  var c;try{c=localStorage.getItem('cookie_consent');}catch(e){c=null;}
  w[l].push(['consent','default',{
    ad_storage:'denied',ad_user_data:'denied',ad_personalization:'denied',
    analytics_storage:c==='granted'?'granted':'denied',
    functionality_storage:'granted',security_storage:'granted'
  }]);
  w[l].push({'gtm.start':new Date().getTime(),event:'gtm.js'});
  var f=d.getElementsByTagName(s)[0],j=d.createElement(s),dl=l!='dataLayer'?'&l='+l:'';
  j.async=true;j.src='https://www.googletagmanager.com/gtm.js?id='+i+dl;
  f.parentNode.insertBefore(j,f);
})(window,document,'script','dataLayer','GTM-W65MZL7G');</script>`} />
    )}

    <!-- Fonts: IBM Plex Mono -->
    <link
      href="https://fonts.googleapis.com/css2?family=IBM+Plex+Mono:wght@300;400;500;600;700&display=swap"
      rel="stylesheet"
    />

    <!-- CSS Crítico para evitar FOUC en mobile -->
    <style>
      @media (max-width: 767px) {
        .section {
          padding-top: calc(var(--nav-h, 8rem) + env(safe-area-inset-top)) !important;
          padding-bottom: 2.5rem !important;
          justify-content: flex-start !important;
        }
      }
    </style>

    <!-- Schema.org JSON-LD -->
    {!noIndex && (
      <script type="application/ld+json" set:html={JSON.stringify({
        "@context": "https://schema.org",
        "@graph": [
          {
            "@type": ["LocalBusiness", "ProfessionalService"],
            "@id": `${siteUrl}/#organization`,
            "name": "RPI Dev",
            "description": lang === 'es'
              ? "Consultoría digital, desarrollo web y automatización de procesos para autónomos y pymes en Granada"
              : "Digital consulting, web development, and process automation for freelancers and SMBs in Granada, Spain",
            "url": siteUrl,
            "email": "ruben@rpidev.com",
            "telephone": "+34614830864",
            "priceRange": "$$",
            "image": ogImage,
            "openingHoursSpecification": [
              {
                "@type": "OpeningHoursSpecification",
                "dayOfWeek": ["Monday", "Tuesday", "Wednesday", "Thursday", "Friday"],
                "opens": "09:00",
                "closes": "18:00"
              }
            ],
            "address": {
              "@type": "PostalAddress",
              "streetAddress": "Calle Ermita 42",
              "addressLocality": "Huétor Vega",
              "addressRegion": "Granada",
              "postalCode": "18198",
              "addressCountry": "ES"
            },
            "geo": {
              "@type": "GeoCoordinates",
              "latitude": 37.1548,
              "longitude": -3.5826
            },
            "areaServed": [
              { "@type": "City", "name": "Granada" },
              { "@type": "Country", "name": "Spain" }
            ],
            "founder": { "@id": `${siteUrl}/#founder` },
            "hasOfferCatalog": {
              "@type": "OfferCatalog",
              "name": lang === 'es' ? "Servicios de desarrollo web y automatización" : "Web development and automation services",
              "itemListElement": [
                {
                  "@type": "Offer",
                  "itemOffered": {
                    "@type": "Service",
                    "name": lang === 'es' ? "Desarrollo Web" : "Web Development",
                    "description": lang === 'es'
                      ? "Diseño y desarrollo de sitios web rápidos, optimizados para SEO y orientados a conversión"
                      : "Design and development of fast, SEO-optimized, conversion-oriented websites"
                  }
                },
                {
                  "@type": "Offer",
                  "itemOffered": {
                    "@type": "Service",
                    "name": lang === 'es' ? "Automatización de procesos" : "Process Automation",
                    "description": lang === 'es'
                      ? "Automatización de tareas repetitivas y flujos de trabajo para ahorrar tiempo"
                      : "Automation of repetitive tasks and workflows to save time"
                  }
                },
                {
                  "@type": "Offer",
                  "itemOffered": {
                    "@type": "Service",
                    "name": lang === 'es' ? "Integraciones de software" : "Software Integrations",
                    "description": lang === 'es'
                      ? "Conexión de CRM, TPV, facturación y otras herramientas empresariales"
                      : "Connecting CRM, POS, invoicing, and other business tools"
                  }
                },
                {
                  "@type": "Offer",
                  "itemOffered": {
                    "@type": "Service",
                    "name": lang === 'es' ? "Consultoría digital" : "Digital Consulting",
                    "description": lang === 'es'
                      ? "Asesoramiento en digitalización y estrategia tecnológica para pymes"
                      : "Digitalization and technology strategy consulting for SMBs"
                  }
                }
              ]
            },
            "sameAs": [
              "https://www.linkedin.com/in/rub%C3%A9n-p%C3%A9rez-izuel-a02607189",
              "https://github.com/rperezpin",
              "https://www.instagram.com/rpi.dev/",
              "https://www.facebook.com/profile.php?id=61583465244829"
            ]
          },
          {
            "@type": "Person",
            "@id": `${siteUrl}/#founder`,
            "name": "Rubén Pérez Izuel",
            "jobTitle": lang === 'es' ? "Desarrollador Web y Consultor Digital" : "Web Developer & Digital Consultant",
            "url": siteUrl,
            "email": "ruben@rpidev.com",
            "worksFor": { "@id": `${siteUrl}/#organization` },
            "sameAs": [
              "https://www.linkedin.com/in/rub%C3%A9n-p%C3%A9rez-izuel-a02607189",
              "https://github.com/rperezpin",
              "https://www.instagram.com/rpi.dev/"
            ]
          },
          {
            "@type": "WebSite",
            "@id": `${siteUrl}/#website`,
            "url": siteUrl,
            "name": "RPI Dev",
            "description": lang === 'es'
              ? "Desarrollo web y automatización para empresas en Granada"
              : "Web development and automation for businesses in Granada, Spain",
            "publisher": { "@id": `${siteUrl}/#organization` },
            "inLanguage": [
              { "@type": "Language", "name": "Spanish", "alternateName": "es" },
              { "@type": "Language", "name": "English", "alternateName": "en" }
            ]
          },
          {
            "@type": "WebPage",
            "@id": canonical,
            "url": canonical,
            "name": title,
            "description": description,
            "isPartOf": { "@id": `${siteUrl}/#website` },
            "about": { "@id": `${siteUrl}/#organization` },
            "inLanguage": lang === 'es' ? 'es-ES' : 'en-US'
          },
          {
            "@type": "FAQPage",
            "mainEntity": lang === 'es'
              ? [
                  {
                    "@type": "Question",
                    "name": "¿Qué servicios de desarrollo web ofrecéis en Granada?",
                    "acceptedAnswer": {
                      "@type": "Answer",
                      "text": "Ofrecemos desarrollo de sitios web rápidos y optimizados para SEO, automatización de procesos empresariales, integración de herramientas (CRM, TPV, facturación) y consultoría digital para autónomos y pymes."
                    }
                  },
                  {
                    "@type": "Question",
                    "name": "¿Cuánto cuesta desarrollar una web profesional?",
                    "acceptedAnswer": {
                      "@type": "Answer",
                      "text": "Cada proyecto se presupuesta de forma personalizada según las necesidades. Ofrecemos un diagnóstico gratuito de 30 minutos para entender tu negocio y presentar una propuesta con coste claro y plazos definidos."
                    }
                  },
                  {
                    "@type": "Question",
                    "name": "¿Cómo funciona la automatización de procesos?",
                    "acceptedAnswer": {
                      "@type": "Answer",
                      "text": "Analizamos tus tareas repetitivas y diseñamos sistemas que las ejecutan automáticamente: envío de emails, sincronización de datos entre herramientas, generación de informes y más. El resultado es un ahorro de tiempo real y medible."
                    }
                  }
                ]
              : [
                  {
                    "@type": "Question",
                    "name": "What web development services do you offer in Granada?",
                    "acceptedAnswer": {
                      "@type": "Answer",
                      "text": "We offer fast, SEO-optimized website development, business process automation, tool integration (CRM, POS, invoicing), and digital consulting for freelancers and SMBs."
                    }
                  },
                  {
                    "@type": "Question",
                    "name": "How much does a professional website cost?",
                    "acceptedAnswer": {
                      "@type": "Answer",
                      "text": "Each project is individually quoted based on your needs. We offer a free 30-minute consultation to understand your business and present a clear proposal with defined costs and timelines."
                    }
                  },
                  {
                    "@type": "Question",
                    "name": "How does process automation work?",
                    "acceptedAnswer": {
                      "@type": "Answer",
                      "text": "We analyze your repetitive tasks and design systems that execute them automatically: sending emails, syncing data between tools, generating reports, and more. The result is real, measurable time savings."
                    }
                  }
                ]
          }
        ]
      })} />
    )}
  </head>
  <body>
    <!-- Google Tag Manager (noscript) -->
    {import.meta.env.PROD && (
      <noscript>
        <iframe
          src="https://www.googletagmanager.com/ns.html?id=GTM-W65MZL7G"
          height="0" width="0"
          style="display:none;visibility:hidden"
          title="Google Tag Manager"
        />
      </noscript>
    )}

    <slot />

    <!-- Cookie Banner -->
    <div
      id="cookie-banner"
      hidden
      role="dialog"
      aria-live="polite"
      aria-label={lang === 'es' ? 'Aviso de cookies' : 'Cookie notice'}
      class="fixed bottom-4 left-4 right-4 sm:left-auto sm:right-6 sm:bottom-6 sm:max-w-sm bg-[#0f172a] border border-white/10 text-slate-200 shadow-2xl rounded-2xl p-5 z-[9999]"
    >
      <p class="text-sm leading-relaxed mb-4">
        {cookieText}
        {' '}<a href={cookiesHref} class="underline underline-offset-2 hover:text-white transition-colors">{cookieLearnMore}</a>.
      </p>
      <div class="flex gap-2 justify-end">
        <button
          id="cookie-decline"
          class="text-xs px-4 py-2 rounded-lg border border-white/20 hover:bg-white/10 transition-colors"
        >{cookieDecline}</button>
        <button
          id="cookie-accept"
          class="text-xs px-4 py-2 rounded-lg bg-blue-600 hover:bg-blue-500 text-white font-semibold transition-colors"
        >{cookieAccept}</button>
      </div>
    </div>

    <script is:inline>
      (function () {
        var banner = document.getElementById('cookie-banner');
        if (!banner) return;

        function getConsent() {
          try { return localStorage.getItem('cookie_consent'); } catch { return null; }
        }

        function applyConsent(value) {
          try { localStorage.setItem('cookie_consent', value); } catch {}
          window.dataLayer = window.dataLayer || [];
          window.dataLayer.push(['consent', 'update', {
            analytics_storage: value === 'granted' ? 'granted' : 'denied'
          }]);
          if (value === 'granted') {
            window.dataLayer.push({ event: 'cookie_consent_granted' });
          }
        }

        function hideBanner() {
          banner.hidden = true;
          banner.style.display = 'none';
        }

        var consent = getConsent();
        if (consent === 'granted' || consent === 'denied') {
          applyConsent(consent);
          hideBanner();
        } else {
          banner.style.display = 'block';
          banner.removeAttribute('hidden');
        }

        document.getElementById('cookie-accept').addEventListener('click', function () {
          applyConsent('granted');
          hideBanner();
        });

        document.getElementById('cookie-decline').addEventListener('click', function () {
          applyConsent('denied');
          hideBanner();
        });
      })();
    </script>
  </body>
</html>
